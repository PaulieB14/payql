# ---------------------------------------------------------------------------
# PayQL configuration. Copy to .env for local runs, or set these as the `env`
# block of your MCP client config (Claude Desktop / Claude Code / Cursor).
# NEVER commit a real private key.
# ---------------------------------------------------------------------------

# Network: "base" (mainnet, default) or "base-sepolia" (testnet).
PAYQL_NETWORK=base

# --- Payment mode -----------------------------------------------------------
# wallet   : sign x402 payments with PAYQL_PRIVATE_KEY  (BYO wallet, default)
# harness  : DON'T pay; return the 402 quote so a wallet-equipped harness pays
# managed  : same signing path as `wallet`, intended for a managed/capped
#            wallet (e.g. Ampersend). Set PAYQL_WALLET_PROVIDER=ampersend.
PAYQL_PAYMENT_MODE=wallet

# BYO wallet private key (32-byte hex, with or without 0x). USDC-only is enough
# — x402 payments are GASLESS (EIP-3009), so no ETH is required to pay queries.
# X402_PRIVATE_KEY is also accepted for compatibility with @graphprotocol/client-x402.
PAYQL_PRIVATE_KEY=

# Optional label for the wallet source (informational), e.g. "ampersend".
PAYQL_WALLET_PROVIDER=

# Hard ceiling per query, in USD. Quotes above this are refused. Default 0.10.
PAYQL_MAX_USD_PER_QUERY=0.10

# Optional: a FREE GraphQL endpoint for discovery (search_subgraphs / schema),
# e.g. your own curated subgraph registry. If unset, discovery runs a tiny
# *paid* x402 query against The Graph's network subgraph.
PAYQL_REGISTRY_URL=

# Advanced overrides (sensible defaults per network) -------------------------
# PAYQL_RPC_URL=https://mainnet.base.org
# PAYQL_GATEWAY_BASE=https://gateway.thegraph.com/api/x402
# PAYQL_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# PAYQL_NETWORK_SUBGRAPH_ID=DZz4kDTdmzWLWsV373w2bSmoar3umKKH9y82SUKr5qmp

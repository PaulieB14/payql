{
  "name": "payql-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Try x402-paid queries on The Graph in the browser — discover → 402 → pay $0.01 → data, transparently.",
  "scripts": {
    "prestart": "npm run build",
    "start": "node server.js",
    "build": "esbuild src/browser.js --bundle --format=esm --outfile=public/bundle.js --inject:./buffer-shim.js --define:global=globalThis"
  },
  "engines": { "node": ">=18" },
  "dependencies": {
    "@x402/evm": "^2.16.0",
    "@x402/fetch": "^2.16.0",
    "buffer": "^6.0.3",
    "esbuild": "^0.23.0",
    "express": "^4.19.2",
    "viem": "^2.21.0"
  }
}

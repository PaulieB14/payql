# A small Base wallet that funds the demo's pay-per-query (USDC only — gasless).
# Fund it with a few dollars of USDC; each demo query costs ~$0.01.
# NEVER commit a real key. Server-side only; the browser never sees it.
DEMO_PRIVATE_KEY=

# Global cap so a demo wallet can't be drained (queries before it stops). Default 200.
DEMO_MAX_QUERIES=200

PORT=3000
